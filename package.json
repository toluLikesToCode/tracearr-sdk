{
  "name": "tracearr-sdk",
  "version": "0.0.2",
  "author": "Tolu Adegbehingbe",
  "bugs": {
    "url": "https://github.com/toluLikesToCode/tracearr-sdk/issues"
  },
  "description": "TypeScript SDK for the Tracearr public API.",
  "homepage": "https://github.com/toluLikesToCode/tracearr-sdk#readme",
  "keywords": [
    "tracearr",
    "sdk",
    "typescript",
    "api-client"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toluLikesToCode/tracearr-sdk.git"
  },
  "type": "module",
  "main": "./esm/index.js",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./esm/index.d.ts",
      "default": "./esm/index.js"
    },
    "./package.json": "./package.json",
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./esm/types/index.d.ts",
      "default": "./esm/types/index.js"
    },
    "./models/errors": {
      "source": "./src/models/errors/index.ts",
      "types": "./esm/models/errors/index.d.ts",
      "default": "./esm/models/errors/index.js"
    },
    "./models": {
      "source": "./src/models/index.ts",
      "types": "./esm/models/index.d.ts",
      "default": "./esm/models/index.js"
    },
    "./models/operations": {
      "source": "./src/models/operations/index.ts",
      "types": "./esm/models/operations/index.d.ts",
      "default": "./esm/models/operations/index.js"
    },
    "./*.js": {
      "source": "./src/*.ts",
      "types": "./esm/*.d.ts",
      "default": "./esm/*.js"
    },
    "./*": {
      "source": "./src/*.ts",
      "types": "./esm/*.d.ts",
      "default": "./esm/*.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "lint": "oxlint --max-warnings=0 --deny-warnings 'src/**/*.{ts,tsx}'",
    "build": "tsgo",
    "refresh:spec": "bash ./scripts/refresh-spec.sh",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "oxlint": "^1.50.0",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "zod": "^3.25.65 || ^4.0.0"
  }
}
